{
    "name": "sebastianbolivart/envia-shipping",
    "description": "Production-ready Envia.com shipping integration module for PrestaShop 9",
    "type": "prestashop-module",
    "license": "AFL-3.0",
    "authors": [
        {
            "name": "Sebastian Bolivar",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "EnviaShipping\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "classmap-authoritative": false,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
